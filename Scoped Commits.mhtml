:root { --bg: #222; --fg: #eee; --fg-muted: #aaa; --fg-subtle: #777; --bord=
er: #444; --code-bg: #333; --link: #84B4FF; }

@media (prefers-color-scheme: light) {
  :root { --bg: #f9f9f9; --fg: #111; --fg-muted: #555; --fg-subtle: #888; -=
-border: #ccc; --code-bg: #ebebeb; --link: #0055cc; }
}

body { background-color: var(--bg); color: var(--fg); font-family: Iosevka,=
 monospace; line-height: 1.4; font-size: 1.1rem; width: 100%; display: flex=
